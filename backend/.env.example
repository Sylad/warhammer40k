# Warhammer 40K Codex — Backend env (NestJS)
# Copie ce fichier en .env et remplis les valeurs.

# Clé API Anthropic — utilisée pour générer/enrichir le lore via Claude
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Port d'écoute
PORT=3001

# Origine autorisée pour le CORS (URL du frontend)
CORS_ORIGIN=http://localhost:4201

# PIN d'écriture (optionnel) — protège les endpoints d'écriture :
# POST /image-import/save, POST /image-meta, POST /units/:id/description,
# POST /series/:id/description, PUT /claude/balance.
# Si vide ou non défini, pas de protection (mode dev). Si défini, le
# frontend prompte l'utilisateur à la 1ère écriture et mémorise en
# sessionStorage.
# APP_PIN=4242
